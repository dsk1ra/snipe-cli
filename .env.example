# snipe-cli — Environment Variables
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# .env is gitignored — your keys never get committed.

# ── Apify (optional) ──────────────────────────────────────────────────────────
# Only needed for Apify-backed portal scans (LinkedIn, Indeed, Glassdoor actors).
# Without it, those providers are skipped; the rest of the pipeline still runs.
# Alternatively set `api_key:` on the entry in portals.yml.
# Get a key: https://console.apify.com/account/integrations
APIFY_API_KEY=your_apify_api_key_here

# ── Optional overrides ────────────────────────────────────────────────────────
# Path to your portals file (default: portals.yml)
# SNIPE_PORTALS=portals.yml
